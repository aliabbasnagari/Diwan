# Copy this file to .env (same folder as docker-compose.yml) and fill in
# your Navidrome server's URL. Crate authenticates against this server's
# admin login — only accounts with isAdmin=true on Navidrome can sign in.
#
# If Navidrome runs as its own container on this same docker-compose
# stack (see the commented-out `navidrome:` service in docker-compose.yml),
# use the service name instead of localhost, e.g.:
#   NAVIDROME_URL=http://navidrome:4533
#
# If Navidrome runs elsewhere — another container, another host, a
# managed instance — point straight at it:
#   NAVIDROME_URL=https://music.example.com

NAVIDROME_URL=http://localhost:4533
